[Unit]
Description=Run the aureon invoice auto-downloader weekly (Mon 09:00)

[Timer]
# D7: weekly. Mon 09:00 local time. Persistent=true runs a missed job on next
# boot (laptop/homelab asleep at the scheduled time still catches up).
OnCalendar=Mon *-*-* 09:00:00
Persistent=true

[Install]
WantedBy=timers.target
